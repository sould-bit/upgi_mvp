							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 201 Created or 409 Conflict', function() {",
									"    pm.expect([201, 409]).to.include(pm.response.code);",
									"});",
									"",
									"if (pm.response.code === 201) {",
									"    pm.test('Response has user_id', function() {",
									"        var jsonData = pm.response.json();",
									"        pm.expect(jsonData).to.have.property('user_id');",
									"    });",
									"} else {",
									"    pm.test('Conflict handled using generated email', function() {",
									"        pm.expect(pm.collectionVariables.get('test_email')).to.be.a('string').and.not.empty;",
									"    });",
