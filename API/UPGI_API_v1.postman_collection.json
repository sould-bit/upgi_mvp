		{
			"name": "Reservas",
			"item": [
				{
					"name": "Crear Reserva",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"function pad(n) { return n < 10 ? '0' + n : String(n); }",
									"var fecha = new Date();",
									"fecha.setDate(fecha.getDate() + 1 + Math.floor(Math.random() * 20));",
									"var fechaIso = fecha.getFullYear() + '-' + pad(fecha.getMonth() + 1) + '-' + pad(fecha.getDate());",
									"var startHour = 8 + Math.floor(Math.random() * 10);",
									"var horaInicio = pad(startHour) + ':00:00';",
									"var horaFin = pad(startHour + 2) + ':00:00';",
									"pm.collectionVariables.set('reserva_fecha', fechaIso);",
									"pm.collectionVariables.set('reserva_hora_inicio', horaInicio);",
									"pm.collectionVariables.set('reserva_hora_fin', horaFin);"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
							"exec": [
								"pm.test('Status 201 Created or 409 Conflict', function() {",
								"    pm.expect([201, 409]).to.include(pm.response.code);",
								"});",
								"",
								"if (pm.response.code === 201) {",
								"    pm.test('Response has reserva data', function() {",
								"        var jsonData = pm.response.json();",
								"        pm.expect(jsonData).to.have.property('reserva');",
								"        var reservaId = jsonData.reserva.id || jsonData.reserva.reserva_id || jsonData.reserva_id || jsonData.id;",
								"        pm.expect(reservaId, 'reserva_id debe existir en la respuesta').to.exist;",
								"        pm.collectionVariables.set('reserva_id', String(reservaId));",
								"        console.log('reserva_id saved:', reservaId);",
								"    });",
								"} else {",
								"    var conflictData = {};",
								"    try { conflictData = pm.response.json(); } catch (e) {}",
								"    var conflictReservaId = conflictData.reserva_id || (conflictData.reserva && (conflictData.reserva.id || conflictData.reserva.reserva_id));",
								"    if (conflictReservaId) {",
								"        pm.collectionVariables.set('reserva_id', String(conflictReservaId));",
								"    }",
								"    pm.test('409 conflict handled without clearing reserva_id', function() {",
								"        pm.expect(true).to.be.true;",
								"    });",
								"}"
							],
							"type": "text/javascript"
						}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
